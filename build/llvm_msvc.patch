+        "@llvm//platforms/config:abi_msvc": [
+            # TODO: should we declare something here?
+            # "@mingw//:mingw_headers",
+        ],
         "@platforms//os:none": [],
     }),
 )
@@ -494,9 +505,13 @@

 CRT_CFLAGS = [
     "-std=c11",
-    "-fPIC",
     "-fno-addrsig",
-]
+] + select({
+    "@platforms//os:windows": [],
+    "//conditions:default": [
+        "-fPIC",
+    ],
+})

 CRT_DEFINES = [
     "CRT_HAS_INITFINI_ARRAY",
