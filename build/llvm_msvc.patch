Subject: [PATCH] Add MSVC support
---
Index: .bazelrc
IDEA additional info:
Subsystem: com.intellij.openapi.diff.impl.patch.CharsetEP
<+>UTF-8
===================================================================
diff --git a/.bazelrc b/.bazelrc
--- a/.bazelrc	(revision 14ef13bb635bb3b57adb2719c584ab65c9658d3f)
+++ b/.bazelrc	(revision 4fe04ee971c2ddfab9b3c94a23835be44299747c)
@@ -8,6 +8,8 @@
 # https://bazelbuild.slack.com/archives/C014RARENH0/p1691158021917459?thread_ts=1691156601.420349&cid=C014RARENH0
 common --config=ruleset

+# TODO: to be discussed
+common --repo_env=BAZEL_MSVC_RUNTIME_VISUAL_STUDIO_EULA=1
 common --repo_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1
 common --repo_env=BAZEL_NO_APPLE_CPP_TOOLCHAIN=1
 common --repo_env=BAZEL_DO_NOT_DETECT_SWIFT_TOOLCHAIN=1
