Subject: [PATCH] Exclude mlgo-utils from LLVM source extraction (Windows hardlink compat)
---
diff --git a/extensions/llvm_source.bzl b/extensions/llvm_source.bzl
--- a/extensions/llvm_source.bzl
+++ b/extensions/llvm_source.bzl
@@ -82,6 +82,7 @@ def _llvm_source_archive_excludes():
         "orc-rt",
         "libclc",
         "offload",
         "libc/docs",
         "libc/utils/gn",
+        "llvm/utils/mlgo-utils/*",
     ]
