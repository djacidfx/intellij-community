<!--suppress PluginXmlRegistrationCheck -->
<idea-plugin>
  <extensionPoints>
    <extensionPoint name="minimapStructureMarkerPolicy"
                    interface="com.intellij.ide.minimap.model.MinimapStructureMarkerPolicy"
                    dynamic="true"/>
    <extensionPoint name="minimapStructureModelProvider"
                    interface="com.intellij.ide.minimap.model.MinimapStructureModelProvider"
                    dynamic="true"/>
    <extensionPoint name="minimapStructureMarkerSourceProvider"
                    interface="com.intellij.ide.minimap.model.MinimapStructureMarkerSourceProvider"
                    dynamic="true"/>
    <extensionPoint name="minimapLayerFactory"
                    interface="com.intellij.ide.minimap.layers.MinimapLayerFactory"
                    dynamic="true"/>
    <extensionPoint name="minimapLayerVisibilityPolicy"
                    interface="com.intellij.ide.minimap.layers.MinimapLayerVisibilityPolicy"
                    dynamic="true"/>
    <extensionPoint name="minimapLayoutProfileProvider"
                    interface="com.intellij.ide.minimap.layout.MinimapLayoutProfileProvider"
                    dynamic="true"/>
    <extensionPoint name="minimapTokenRenderPolicy"
                    interface="com.intellij.ide.minimap.render.MinimapTokenRenderPolicy"
                    dynamic="true"/>
    <extensionPoint name="minimapHoverPolicy"
                    interface="com.intellij.ide.minimap.hover.MinimapHoverPolicy"
                    dynamic="true"/>
    <extensionPoint name="minimapFileSupportPolicy"
                    interface="com.intellij.ide.minimap.model.MinimapFileSupportPolicy"
                    dynamic="true"/>
  </extensionPoints>
</idea-plugin>
